# Aura AI Backend Configuration

# Gemini API Key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Server Port
PORT=5013

# JWT secret for auth tokens (use long random string)
JWT_SECRET=replace_with_strong_secret

# Email Configuration (Gmail with App Password)
EMAIL_USER=your_gmail@gmail.com
EMAIL_APP_PASSWORD=your_gmail_app_password

# Recipient Email for notifications
RECIPIENT_EMAIL=shubharthaksangharsha@gmail.com

# Google Maps Places API key for checkout address autocomplete
GOOGLE_MAPS_API_KEY=your_google_maps_places_api_key

# Admin dashboard credentials (server-side only; restart backend after changes)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_strong_password

# Public base URL of THIS backend (used to build absolute URLs for uploaded
# images so they load on the static frontend). e.g. https://aura.devshubh.me
# If unset, it is derived from the incoming request host.
PUBLIC_BASE_URL=

# WhatsApp order notifications via CallMeBot (free)
# Setup: https://www.callmebot.com/blog/free-api-whatsapp-messages/
# 1. Save CallMeBot number on client's phone
# 2. Send the activation message from WhatsApp
# 3. Receive the API key and enter it below
CALLMEBOT_PHONE=919876543210
CALLMEBOT_API_KEY=your_callmebot_api_key

# Firebase Cloud Messaging (admin order pushes). Optional if
# aura-ai/backend/firebase-service-account.json exists on the server.
# FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
