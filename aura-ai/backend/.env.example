# Aura AI Backend Configuration

# Gemini API Key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Server Port
PORT=5013

# JWT secret for auth tokens (use long random string)
JWT_SECRET=replace_with_strong_secret

# Email Configuration (Gmail with App Password)
EMAIL_USER=your_gmail@gmail.com
EMAIL_APP_PASSWORD=your_gmail_app_password

# Recipient Email for notifications
RECIPIENT_EMAIL=shubharthaksangharsha@gmail.com

# Google Maps Places API key for checkout address autocomplete
GOOGLE_MAPS_API_KEY=your_google_maps_places_api_key

# Admin dashboard credentials (server-side only)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_strong_password
ADMIN_JWT_SECRET=change_me_admin_jwt_secret
